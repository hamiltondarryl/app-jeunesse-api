// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActionType {
  LOGIN // Connexion utilisateur
  LOGOUT // Déconnexion utilisateur
  OTHER // Autres actions
  PASSWORD_RESET // Réinitialisation du mot de passe
  PASSWORD_CHANGE // Modification du mot de passe
  FORGOT_PASSWORD // Demande de réinitialisation du mot de passe
  ACCOUNT_CREATED // Creation du compte 
  ACCOUNT_ACTIVATION // Actived du compte
}

enum StatutCandidature {
  EN_ATTENTE
  ACCEPTEE
  REJETEE
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  username       String?       @unique
  password       String
  roleId         String
  passwordIsRest Boolean        @default(false)
  fcmToken  String?
  activated      Boolean       @default(false)
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  candidatId     String? // Référence à Candidat, si applicable
  juryMembreId   String? // Référence à JuryMembre, si applicable
  candidat       Candidat?
  jury           JuryMembre?
  ActivityLog    ActivityLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  @@unique([email, code])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  code        String       @unique
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TypeCandidat {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  candidats   Candidat[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Groupe {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  candidats   Candidat[] // Relation un-à-plusieurs avec Candidat
  Category    Category[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Candidat {
  id             String        @id @default(uuid())
  user           User          @relation(fields: [userId], references: [id])
  userId         String        @unique
  typeCandidatId String
  typeCandidat   TypeCandidat  @relation(fields: [typeCandidatId], references: [id], onDelete: Restrict)
  groupeId       Int // Référence au groupe
  groupe         Groupe        @relation(fields: [groupeId], references: [id], onDelete: Restrict)
  candidatures   Candidature[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Candidature {
  id          String            @id @default(uuid())
  candidat    Candidat          @relation(fields: [candidatId], references: [id], onDelete: Restrict)
  candidatId  String
  edition     Edition           @relation(fields: [editionId], references: [id])
  editionId   String
  category    Category          @relation(fields: [categoryId], references: [id])
  categoryId  String
  documentUrl String?
  description String
  moyenneNote Float?            @default(0)
  statut      StatutCandidature @default(EN_ATTENTE)
  notations   Notation[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Edition {
  id           String        @id @default(uuid())
  year         Int           @unique
  activated    Boolean       @default(false)
  candidatures Candidature[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Category {
  id           String        @id @default(uuid())
  nom          String
  groupeId     Int // Référence au groupe
  groupe       Groupe        @relation(fields: [groupeId], references: [id], onDelete: Restrict)
  candidatures Candidature[]
}

model Jury {
  id        String       @id @default(uuid())
  name      String
  membres   JuryMembre[]
  notations Notation[]
}

model JuryMembre {
  id        String     @id @default(uuid())
  user      User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId    String     @unique
  jury      Jury       @relation(fields: [juryId], references: [id], onDelete: Restrict)
  juryId    String
  notations Notation[] // Chaque membre du jury a plusieurs notations
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Notation {
  id            String       @id @default(uuid())
  jury          Jury         @relation(fields: [juryId], references: [id], onDelete: Restrict)
  juryId        String
  candidature   Candidature  @relation(fields: [candidatureId], references: [id], onDelete: Restrict)
  candidatureId String
  note          Int
  commentaire   String?
  JuryMembre    JuryMembre[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model ActivityLog {
  id          String     @id @default(uuid()) // ID unique
  action      ActionType // Type d'action
  description String? // Détails sur l'action
  userId      String? // ID de l'utilisateur ayant effectué l'action
  user        User?      @relation(fields: [userId], references: [id], onDelete: Restrict) // Relation avec le modèle User
  createdAt   DateTime   @default(now()) // Date de l'action
}
