// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ActionType {
  LOGIN // Connexion utilisateur
  LOGOUT // Déconnexion utilisateur
  OTHER // Autres actions
  PASSWORD_RESET // Réinitialisation du mot de passe
  PASSWORD_CHANGE // Modification du mot de passe
  FORGOT_PASSWORD // Demande de réinitialisation du mot de passe
  ACCOUNT_CREATED // Creation du compte 
  ACCOUNT_ACTIVATION // Actived du compte
}

enum TypeOSC {
  ONG
  Association
  Coopérative
  Autre
}

enum Sexe {
  Masculin
  Féminin
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  username       String?       @unique
  password       String
  roleId         String
  passwordIsRest Boolean       @default(false)
  fcmToken       String?
  activated      Boolean       @default(false)
  passwordDefault   Boolean       @default(true)
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  ActivityLog    ActivityLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime

  @@unique([email, code])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  code        String       @unique
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Organisation {
  id                           String        @id @default(uuid())
  nom                          String
  sigle                        String?
  type                         String?
  anneeCreation                Int?
  agrementTechniqueDelivred    Boolean
  adresse                      String?
  commune                      String?
  international                Boolean
  typeRecepice                 String?
  rib                          String?
  recepice                     String?
  recepiceProvisoirOuDefinitif String?
  groupes                      Int?
  adherents                    Int?
  hommes                       Int?
  femmes                       Int?
  salaries                     Int?
  benevoles                    Int?
  cotisationMensuelle          Float?
  partenaires                  String?
  but                          String?
  publicCible                  String?
  responsable                  Responsable?  @relation("OrganisationResponsable", fields: [responsableId], references: [id])
  secretaireGeneral            Responsable?  @relation("OrganisationSecretaireGeneral", fields: [secretaireGeneralId], references: [id])
  tresorier                    Responsable?  @relation("OrganisationTresorier", fields: [tresorierId], references: [id])
  responsableId                String?
  secretaireGeneralId          String?
  tresorierId                  String?
  domaines                     Domaine[]     @relation("OrganisationDomaines")
  activated                    Boolean       @default(false)
  updatedAt                    DateTime      @updatedAt
  createdAt                    DateTime      @default(now())
  departements                 Departement[] @relation("OrganisationDepartements")
}

model Responsable {
  id                               String         @id @default(uuid())
  nom                              String         
  age                              Int?
  nationalite                      String?
  situation                        String?
  situationMatrimoniale            String?
  telephone                        String?
  email                            String?
  adresse                          String?
  pieceIdentite                    String?
  organisationsAsResponsable       Organisation[] @relation("OrganisationResponsable")
  organisationsAsSecretaireGeneral Organisation[] @relation("OrganisationSecretaireGeneral")
  updatedAt                        DateTime       @updatedAt
  createdAt                        DateTime       @default(now())

  organisations Organisation[] @relation("OrganisationTresorier")
}

model Domaine {
  id            String         @id @default(uuid())
  nom           String         @unique
  organisations Organisation[] @relation("OrganisationDomaines")
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())
}

model ActivityLog {
  id          String     @id @default(uuid()) // ID unique
  action      ActionType // Type d'action
  description String? // Détails sur l'action
  userId      String? // ID de l'utilisateur ayant effectué l'action
  user        User?      @relation(fields: [userId], references: [id], onDelete: Restrict) // Relation avec le modèle User
  createdAt   DateTime   @default(now()) // Date de l'action
}

model Province {
  id           String        @id @default(uuid())
  nom          String        @unique
  abreviation  String        @unique
  departements Departement[]
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())
}

model Departement {
  id            String         @id @default(uuid())
  nom           String
  province      Province       @relation(fields: [provinceId], references: [id])
  provinceId    String
  organisations Organisation[] @relation("OrganisationDepartements")
  updatedAt     DateTime       @updatedAt
  createdAt     DateTime       @default(now())

  @@unique([nom, provinceId])
}
