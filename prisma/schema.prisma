// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActionType {
  LOGIN // Connexion utilisateur
  LOGOUT // Déconnexion utilisateur
  OTHER // Autres actions
  PASSWORD_RESET // Réinitialisation du mot de passe
  PASSWORD_CHANGE // Modification du mot de passe
  FORGOT_PASSWORD // Demande de réinitialisation du mot de passe
  ACCOUNT_CREATED // Creation du compte 
  ACCOUNT_ACTIVATION // Actived du compte
}
enum TypeOSC {
  ONG
  Association
  Coopérative
  Autre
}

enum Sexe {
  Masculin
  Féminin
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  username       String?       @unique
  password       String
  roleId         String
  passwordIsRest Boolean       @default(false)
  fcmToken       String?
  activated      Boolean       @default(false)
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  ActivityLog    ActivityLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime

  @@unique([email, code])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  code        String       @unique
  description String?
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Organisation {
  id                 String       @id @default(uuid())
  nom                String
  sigle              String?
  type               String?
  anneeCreation      Int?
  agrementTechnique  Boolean
  adresse            String?
  commune            String?
  international      Boolean
  groupes            Int?
  adherents          Int?
  hommes             Int?
  femmes             Int?
  salaries           Int?
  benevoles          Int?
  cotisationMensuelle Float?
  partenaires        Boolean
  but                String?
  publicCible        String?
  zones              String[]
  responsable        Responsable? @relation(fields: [responsableId], references: [id])
  responsableId      String?
  domaines           Domaine[]    @relation("OrganisationDomaines")
  contacts           Contact[]
  provinces  Province[]  @relation("OrganisationProvinces")
  createdAt          DateTime     @default(now())
}

model Responsable {
  id           String         @id @default(uuid())
  nom          String         @unique
  age          Int?
  nationalite  String?
  situation    String?
  telephone    String?
  email        String?
  adresse      String?
  organisation Organisation[]
}


model Domaine {
  id             String         @id @default(uuid())
  nom            String         @unique
  organisations  Organisation[] @relation("OrganisationDomaines")
}

model Contact {
  id             String       @id @default(uuid())
  nom            String
  telephone      String?
  email          String?
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  organisationId String
}

model ActivityLog {
  id          String     @id @default(uuid()) // ID unique
  action      ActionType // Type d'action
  description String? // Détails sur l'action
  userId      String? // ID de l'utilisateur ayant effectué l'action
  user        User?      @relation(fields: [userId], references: [id], onDelete: Restrict) // Relation avec le modèle User
  createdAt   DateTime   @default(now()) // Date de l'action
}
model Province{
  id          String     @id @default(uuid()) // ID unique
  nom          String         @unique
  anbreviation          String         @unique
  organisations Organisation[] @relation("OrganisationProvinces")
}